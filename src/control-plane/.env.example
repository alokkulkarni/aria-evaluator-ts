# ─── ARIA Control Plane ────────────────────────────────────────────────────────

# Port the server listens on (default: 3002)
# CONTROL_PLANE_PORT=3002

# Base URL of the evaluator instance (used to build the SSO redirect URL)
# Must NOT end with a trailing slash.
# Local:  http://localhost:3001
# Prod:   https://<tenant>.ariaeval.io
CONTROL_PLANE_INSTANCE_BASE_URL=http://localhost:3001

# Comma-separated list of allowed CORS origins (leave empty to allow localhost in dev)
# CONTROL_PLANE_CORS_ORIGINS=https://aria.example.com

# Shared secret for the internal /auth/verify-sso-token endpoint.
# Set the same value in the evaluator's CONTROL_PLANE_INTERNAL_SECRET.
# Leave unset for local development (endpoint is then open to any caller).
# CONTROL_PLANE_INTERNAL_SECRET=<strong-random-secret>

# Path to JSON state file (default: ./state/control-plane-state.json)
# CONTROL_PLANE_STATE_PATH=./state/control-plane-state.json
