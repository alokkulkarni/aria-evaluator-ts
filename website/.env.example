# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
ARIA_DEPLOY_ENV=local
NEXTAUTH_SECRET=your-32-char-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Apple Sign In (requires Apple Developer Account)
# https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_CLIENT_ID=         # Services ID e.g. io.ariaeval.auth
APPLE_CLIENT_SECRET=     # Signed JWT generated from .p8 private key

# Control Plane API (separate backend)
NEXT_PUBLIC_CONTROL_PLANE_URL=/api/control-plane
CONTROL_PLANE_INTERNAL_URL=http://localhost:3002

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ARIA Evaluator
