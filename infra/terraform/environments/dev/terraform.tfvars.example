# ── Dev environment — example tfvars ─────────────────────────────────────────
# Copy to terraform.tfvars and replace all REPLACE_* placeholders.
# terraform.tfvars is gitignored; this example file is safe to commit.

# ── Core ──────────────────────────────────────────────────────────────────────
aws_region  = "eu-west-2"
app_name    = "aria-evaluator"
environment = "dev"

# Short unique suffix for the S3 bucket name (e.g. last 6 digits of account ID)
bucket_suffix = "123456"

# ── Networking ────────────────────────────────────────────────────────────────
vpc_cidr            = "10.42.0.0/16"
public_subnet_cidrs = ["10.42.1.0/24", "10.42.2.0/24"]

# ── ECS ───────────────────────────────────────────────────────────────────────
# Placeholder — replace after first apply once ECR is created and image is pushed.
app_image_uri  = "123456789012.dkr.ecr.eu-west-2.amazonaws.com/aria-evaluator:latest"
container_port = 3001
cpu            = 256
memory         = 512
desired_count  = 1

s3_state_prefix          = "aria-evaluator"
s3_sync_interval_seconds = 30
log_retention_days       = 7

# ── Amazon Connect ────────────────────────────────────────────────────────────
connect_instance_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ── CloudFront ────────────────────────────────────────────────────────────────
cloudfront_price_class = "PriceClass_100"
acm_certificate_arn    = ""
cloudfront_aliases     = []

# ── Bedrock Lambda proxy ──────────────────────────────────────────────────────
# Deploy independently from the evaluator — set bedrock_lambda_enabled = true
# to create the Lambda + API Gateway. The evaluator and proxy share the same
# Terraform state but can be targeted individually:
#
#   Deploy proxy only:
#     terraform apply -var="bedrock_lambda_enabled=true" \
#       -target=module.bedrock_lambda
#
#   Deploy evaluator only:
#     terraform apply -target=module.networking -target=module.ecr \
#       -target=module.s3 -target=module.iam -target=module.alb \
#       -target=module.ecs -target=module.cloudfront
#
# Or use the deploy script:
#   ./infra/terraform/scripts/deploy.sh -e dev -c bedrock
#   ./infra/terraform/scripts/deploy.sh -e dev -c evaluator
bedrock_lambda_enabled     = false
bedrock_model_id           = "eu.anthropic.claude-sonnet-4-5-20250929-v1:0"
bedrock_region             = "eu-west-2"
bedrock_system_prompt      = "You are a helpful AI assistant for customer service evaluation."
bedrock_allowed_origins    = "*"
bedrock_lambda_memory_size = 512
bedrock_lambda_timeout     = 120

# ── App-specific environment variables ────────────────────────────────────────
extra_environment_vars = [
  { name = "CONNECT_INSTANCE_ID",           value = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" },
  { name = "CONNECT_REGION",                value = "eu-west-2" },
  { name = "CONNECT_CONTACT_FLOW_NAME",     value = "conversation bot flow" },
  { name = "CONNECT_WEBRTC_FLOW_ID",        value = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" },
  { name = "BEDROCK_REGION",                value = "eu-west-2" },
  { name = "JUDGE_MODEL_ID",                value = "eu.anthropic.claude-sonnet-4-5-20250929-v1:0" },
  { name = "EVAL_CUSTOMER_ID",              value = "CUST-001" },
  { name = "EVAL_CUSTOMER_NAME",            value = "James Wilson" },
  { name = "EVAL_PROVIDER_DEFAULT",         value = "connect" },
  { name = "POLLY_VOICE_ID",                value = "Amy" },
  { name = "EVAL_RESPONSE_TIMEOUT_SECONDS", value = "120" },
  { name = "VOICE_PRE_SEND_DELAY_MS",       value = "1200" },
]

# ── Extra tags ────────────────────────────────────────────────────────────────
tags = {
  CostCentre = "engineering"
  Owner      = "platform-team"
}

# ── Website URL (sign-out redirect target) ────────────────────────────────────
# Leave empty to use the code default. Set to your dev website URL if deployed.
# website_url = "https://dev.ariaeval.io"
