# ── Website Production Deployment (Split Architecture) ─────────────────────────
# Copy this file to terraform.tfvars and fill in real values before deploying.
#
# Architecture:
#   CloudFront (ariaeval.io)
#   ├── /* (default)     → S3 bucket (static website export)
#   ├── /api/*           → ALB → ECS Fargate (auth backend)
#   └── /_next/static/*  → S3 bucket (long-cached assets)

# ── Deploy Steps ──────────────────────────────────────────────────────────────
#
# 1. First-time setup:
#      cd infra/terraform/environments/website-prod
#      terraform init
#      terraform apply
#
# 2. Build & push auth backend image:
#      ECR_URI=$(terraform output -raw auth_ecr_repository_url)
#      cd website/auth-backend && docker build -t $ECR_URI:latest .
#      aws ecr get-login-password --region eu-west-2 | docker login --username AWS --password-stdin $ECR_URI
#      docker push $ECR_URI:latest
#      aws ecs update-service \
#        --cluster $(terraform output -raw auth_ecs_cluster_name) \
#        --service $(terraform output -raw auth_ecs_service_name) \
#        --force-new-deployment
#
# 3. Build & deploy static frontend:
#      cd website && npm run build:static
#      S3_BUCKET=$(terraform output -raw s3_bucket_name)
#      aws s3 sync out/ s3://$S3_BUCKET --delete
#      aws cloudfront create-invalidation \
#        --distribution-id $(terraform output -raw cloudfront_distribution_id) \
#        --paths "/*"

# ── Auth Backend Image Tag ────────────────────────────────────────────────────
# ECR repository is created by Terraform. Push your image then set the tag:
auth_backend_image_tag = "latest"

# ── Auth Secrets (use TF_VAR_ env vars in CI/CD instead of hardcoding) ────────
# nextauth_secret      = "..."
# google_client_id     = "..."
# google_client_secret = "..."
# github_client_id     = "..."
# github_client_secret = "..."

# ── Domain & TLS ──────────────────────────────────────────────────────────────
# 1. Register domain in Route53 (already done: ariaeval.io)
# 2. Get the Hosted Zone ID from Route53 console
# 3. Request ACM cert in us-east-1 (for CloudFront + WAF)
#    - Domain: ariaeval.io  SANs: *.ariaeval.io
# 4. Validate cert via DNS (Route53 auto-validation)

domain_name                   = "ariaeval.io"
route53_zone_id               = ""    # e.g. "Z0123456789ABCDEFGHIJ"
acm_certificate_arn_us_east_1 = "" # e.g. "arn:aws:acm:us-east-1:ACCOUNT:certificate/UUID"

# ── Notifications ─────────────────────────────────────────────────────────────
# alarm_sns_topic_arn = "arn:aws:sns:eu-west-2:ACCOUNT:aria-alarms"

# ── CloudTrail ────────────────────────────────────────────────────────────────
# cloudtrail_bucket_suffix = "prod"
# cloudtrail_kms_key_arn   = ""
