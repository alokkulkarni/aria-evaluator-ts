# ARIA Control Plane — Production
# Copy to terraform.tfvars and fill in values before running terraform apply.

aws_region  = "eu-west-2"
environment = "prod"

# From bootstrap outputs
bucket_suffix      = "REPLACE_WITH_BUCKET_SUFFIX"
kms_key_arn        = "REPLACE_WITH_KMS_KEY_ARN"
cloudtrail_kms_key_arn = ""
ecr_repository_url = "REPLACE_WITH_ACCOUNT_ID.dkr.ecr.eu-west-2.amazonaws.com/aria-control-plane"

# Image tag (auto-built and pushed during terraform apply)
image_tag = "latest"

# CloudTrail alarm topic (create or re-use an existing SNS topic)
cloudtrail_alert_sns_topic_arn = ""

# Provisioning infrastructure — Lambda triggers CodeBuild to provision user instances
terraform_state_bucket      = "aria-evaluator-tf-state-BUCKET_SUFFIX"
terraform_state_kms_key_arn = "REPLACE_WITH_KMS_KEY_ARN"

# GitHub repo and branch for CodeBuild (clones to run terraform apply)
github_repo_url = "https://github.com/alokkulkarni/aria-evaluator-ts.git"
github_branch   = "main"

# CORS allowed origins for provisioning API
allowed_origins = [
  "http://localhost:3000",
  "https://ariaeval.io"
]
