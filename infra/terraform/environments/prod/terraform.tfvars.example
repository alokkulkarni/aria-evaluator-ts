app_name       = "aria-evaluator"
environment    = "prod"
aws_region     = "eu-west-2"
tenant_id      = "tenant-acme"
pricing_tier   = "enterprise_starter"
pricing_track  = "enterprise"

app_image_uri                  = "123456789012.dkr.ecr.eu-west-2.amazonaws.com/aria-evaluator:sha-abcdef0"
acm_certificate_arn            = "arn:aws:acm:eu-west-2:123456789012:certificate/aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"
cloudfront_acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/ffffffff-1111-2222-3333-444444444444"

vpc_cidr             = "10.42.0.0/16"
public_subnet_cidrs  = ["10.42.1.0/24", "10.42.2.0/24"]
private_subnet_cidrs = ["10.42.3.0/24", "10.42.4.0/24"]

bucket_suffix        = "acme123"
heartbeat_table_arn  = "arn:aws:dynamodb:eu-west-2:123456789012:table/aria-heartbeats"
heartbeat_table_name = "aria-heartbeats"
kms_key_arn          = "arn:aws:kms:eu-west-2:123456789012:key/aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"

god_mode_enabled    = true
god_mode_secret_arn = "arn:aws:secretsmanager:eu-west-2:123456789012:secret:aria/tenant-acme/god-mode-token-AbCdEf"

alert_email                      = "platform-alerts@example.com"
control_plane_role_arn           = "arn:aws:iam::123456789012:role/aria-control-plane"
suspend_threshold_hours_override = 0
connect_instance_id              = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
cloudfront_enabled               = true
waf_enabled                      = true
s3_force_destroy                 = true
alb_enable_deletion_protection   = false
cloudtrail_enabled               = false
log_retention_days_override      = 0

tags = {
  Owner               = "platform-team"
  CostCentre          = "engineering"
  "aria:tenant_id"     = "tenant-acme"
  "aria:pricing_tier"  = "enterprise_starter"
  "aria:pricing_track" = "enterprise"
}
