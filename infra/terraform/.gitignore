# ── Terraform state ───────────────────────────────────────────────────────────
*.tfstate
*.tfstate.*
*.tfstate.backup

# ── Terraform working directories ────────────────────────────────────────────
**/.terraform/
**/.terraform.lock.hcl

# ── Variable files with real values ──────────────────────────────────────────
# *.tfvars.example files ARE committed (safe placeholders).
# terraform.tfvars files are NOT committed (contain real values).
**/terraform.tfvars
# Allow example files through
!**/terraform.tfvars.example

# ── Crash logs ────────────────────────────────────────────────────────────────
crash.log
crash.*.log

# ── Override files ────────────────────────────────────────────────────────────
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── Plan files ────────────────────────────────────────────────────────────────
*.tfplan
*.plan

# ── Sensitive variable files ──────────────────────────────────────────────────
*.auto.tfvars
*.auto.tfvars.json
