# ─── Provider defaults ─────────────────────────────────────────────────────────
# connect | lex | azure | custom
EVAL_PROVIDER_DEFAULT=connect

# ─── Amazon Connect ────────────────────────────────────────────────────────────
CONNECT_INSTANCE_ID=f969d4b4-f716-4974-a325-bb7899f2f293
CONNECT_REGION=eu-west-2
# Contact flow — use ID or NAME (auto-resolved if only name given)
# CONNECT_CONTACT_FLOW_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CONNECT_CONTACT_FLOW_NAME="conversation bot flow"
# Phone number for voice (DID that answers ARIA)
CONNECT_PHONE_NUMBER=+441614960000

# ─── Amazon Connect — WebRTC voice adapter (StartWebRTCContact) ────────────────
# Contact Flow ID for the ARIA inbound voice flow (NOT the chat flow)
# Get from: Connect → Routing → Flows → [ARIA voice flow] → Show additional info → last ARN segment
CONNECT_WEBRTC_FLOW_ID=f6d6545f-c9ae-4ca4-a4d8-6fdc8ba0494f
# Optional: retry failed pre-connect signaling attempts (default: 2)
# CONNECT_WEBRTC_CONNECT_ATTEMPTS=2

# ─── Amazon Connect widget (legacy Playwright voice adapter — no longer used) ──
CONNECT_SNIPPET_ID=17638a13-f2b0-4371-a593-1f81f86548e8
CONNECT_WIDGET_HOST=conversationalbot.my.connect.aws

# ─── Amazon Polly — TTS for voice evaluation ───────────────────────────────────
# Recommended: Amy (en-GB neural) — matches ARIA's expected accent
POLLY_VOICE_ID=Amy
# POLLY_REGION=eu-west-2

# ─── Amazon Lex V2 (provider=lex, chat mode) ──────────────────────────────────
# LEX_BOT_ID=<bot-id>
# LEX_BOT_ALIAS_ID=<bot-alias-id>
# LEX_BOT_LOCALE_ID=en_GB
# LEX_REGION=eu-west-2

# ─── Azure Bot Direct Line (provider=azure, chat mode) ────────────────────────
# AZURE_DIRECT_LINE_SECRET=<direct-line-secret>
# AZURE_DIRECT_LINE_ENDPOINT=https://directline.botframework.com/v3/directline
# AZURE_DIRECT_LINE_USER_ID=aria-evaluator-user

# ─── Strands / AgentCore chat (provider=strands, chat mode) ────────────────────
# STRANDS_ENDPOINT=https://<agent-runtime-endpoint>/invocations
# STRANDS_METHOD=POST
#
# Auth type — choose one:
#   none    → no auth header (local dev, open endpoints)
#   bearer  → Authorization: Bearer <token>  (API Gateway + custom authorizer)
#   sigv4   → AWS Signature V4  (Bedrock AgentCore, Lambda function URLs, private API GW)
# STRANDS_AUTH_TYPE=none
#
# Bearer auth (STRANDS_AUTH_TYPE=bearer)
# STRANDS_AUTH_BEARER=<token>
#
# SigV4 auth (STRANDS_AUTH_TYPE=sigv4) — uses default AWS credential chain
# STRANDS_SIGV4_REGION=eu-west-2
# STRANDS_SIGV4_SERVICE=bedrock-agentcore
#   For Bedrock AgentCore:  STRANDS_SIGV4_SERVICE=bedrock-agentcore
#   For Lambda function URL: STRANDS_SIGV4_SERVICE=lambda
#   For API Gateway (IAM auth): STRANDS_SIGV4_SERVICE=execute-api
#
# Field mapping (for agents that use different field names)
# STRANDS_MESSAGE_FIELD=prompt
# STRANDS_RESPONSE_FIELD=result
# STRANDS_HISTORY_FIELD=history
# STRANDS_SESSION_ID_FIELD=sessionId
# STRANDS_HEADERS_JSON={"X-Api-Key":"..."}

# ─── Microsoft Copilot (provider=copilot, chat mode) ───────────────────────────
# COPILOT_DIRECT_LINE_SECRET=<direct-line-secret>
# COPILOT_DIRECT_LINE_ENDPOINT=https://directline.botframework.com/v3/directline
# COPILOT_DIRECT_LINE_USER_ID=aria-evaluator-user

# ─── Custom provider: chat over HTTP (provider=custom, channel=chat) ──────────
# CUSTOM_CHAT_ENDPOINT=https://your-chat-endpoint.example.com/chat
# CUSTOM_CHAT_METHOD=POST
# CUSTOM_CHAT_AUTH_BEARER=<optional-token>
# CUSTOM_CHAT_MESSAGE_FIELD=message
# CUSTOM_CHAT_RESPONSE_FIELD=reply
# CUSTOM_CHAT_HEADERS_JSON={"X-Api-Key":"..."}

# ─── Custom provider: voice over WebSocket (provider=custom, channel=voice) ───
# Protocol options:
#   deepgram     -> uses DEEPGRAM_VOICE_WS_URL + DEEPGRAM_API_KEY
#   agentcore    -> uses CUSTOM_VOICE_WS_URL (+ optional auth/init/template settings)
#   generic-json -> uses CUSTOM_VOICE_WS_URL with template/path settings
CUSTOM_VOICE_PROTOCOL=deepgram
# DEEPGRAM_VOICE_WS_URL=wss://agent.deepgram.com/v1/agent/converse
# DEEPGRAM_API_KEY=<deepgram-api-key>
# DEEPGRAM_VOICE_SETTINGS_JSON={"type":"Settings",...}
# CUSTOM_VOICE_WS_URL=wss://example.com/ws
# CUSTOM_VOICE_WS_AUTH_HEADER_NAME=Authorization
# CUSTOM_VOICE_WS_AUTH_HEADER_VALUE=Bearer <token>
# CUSTOM_VOICE_WS_INIT_JSON={"type":"start"}
# CUSTOM_VOICE_WS_SEND_TEMPLATE={"type":"message","content":"{{message}}"}
# CUSTOM_VOICE_WS_AGENT_EVENT_TYPES=agent,assistant,message,ConversationText
# CUSTOM_VOICE_WS_MESSAGE_PATH=content

# ─── ElevenLabs — optional TTS (higher quality than Polly) ────────────────────
# ELEVENLABS_API_KEY=<your-elevenlabs-api-key>
# ELEVENLABS_VOICE_ID=<voice-id>

# ─── Bedrock — LLM judge + customer simulation agent ──────────────────────────
BEDROCK_REGION=eu-west-2
JUDGE_MODEL_ID=eu.anthropic.claude-sonnet-4-5-20250929-v1:0
# JUDGE_MODEL_ID_LIGHT=eu.anthropic.claude-haiku-4-5-20251014-v1:0
# Bedrock Agent for customer simulation (optional — falls back to direct Converse)
# BEDROCK_AGENT_ID=<agent-id>
# BEDROCK_AGENT_ALIAS_ID=<alias-id>

# ─── Evaluation run config ─────────────────────────────────────────────────────
EVAL_CUSTOMER_ID=CUST-001
EVAL_CUSTOMER_NAME="James Wilson"
EVAL_DISPLAY_NAME=ARIAEvaluatorBot
EVAL_CHAT_DURATION_MINUTES=60
EVAL_RESPONSE_TIMEOUT_SECONDS=120
VOICE_RESPONSE_TIMEOUT=45
VOICE_SILENCE_TIMEOUT=3
# Wait for ARIA greeting before sending first customer turn (WebRTC voice)
VOICE_INITIAL_GREETING_TIMEOUT_MS=120000
VOICE_GREETING_FOLLOWUP_TIMEOUT_MS=6000
# Optional strict mode: fail run if no opening greeting arrives before timeout
# VOICE_REQUIRE_OPENING_GREETING=true
# Short floor delay before speaking each customer turn (helps avoid turn-boundary barging)
VOICE_PRE_SEND_DELAY_MS=1200
# Allow one silent wait cycle; then force a follow-up prompt to avoid infinite waiting loops
VOICE_MAX_CONSECUTIVE_SILENT_WAITS=1
VOICE_SILENT_WAIT_FOLLOWUP_PROMPT="Could you share the result now, please?"
# Before each customer turn, wait this long for any continued ARIA speech
VOICE_PRE_SEND_GUARD_TIMEOUT_MS=4000
# Wait for ARIA to go quiet before sending next customer turn
VOICE_TURN_SETTLE_TIMEOUT_MS=4000
VOICE_TURN_SETTLE_MAX_MS=15000
# Recording cleanup for mixed voice WAV (higher value = stronger noise suppression)
VOICE_AUDIO_NOISE_GATE_PCM=180
EVAL_REPORT_OUTPUT_DIR=./reports

# ─── API server ────────────────────────────────────────────────────────────────
API_PORT=3001
UI_DEV_PORT=5173

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="file:./data/aria-evaluator.db"

# ─── Control plane SSO (SaaS mode) ────────────────────────────────────────────
# Internal URL of the ARIA Control Plane, used for server-side SSO token exchange.
# Local:  http://localhost:3002
# Docker: http://control-plane:3002
# Dev/Prod: injected by Terraform (internal ALB)
# CONTROL_PLANE_INTERNAL_URL=http://localhost:3002

# Shared secret between evaluator and control plane (optional but recommended in prod).
# Set the same value in both services. Leave unset for local/dev convenience.
# CONTROL_PLANE_INTERNAL_SECRET=<strong-random-secret>
