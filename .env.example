# Environment Configuration Template

# Server
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=file:./data/aria.db

# Redis (Phase 1)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT Secrets (generate with: openssl rand -base64 32)
ACCESS_TOKEN_SECRET=your-generated-secret-here
REFRESH_TOKEN_SECRET=your-generated-secret-here

# OAuth - Google
# 1. Go to https://console.cloud.google.com
# 2. Create OAuth 2.0 credentials (Web application)
# 3. Add authorized redirect URIs
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/oauth/google/callback

# OAuth - GitHub
# 1. Go to https://github.com/settings/developers
# 2. Create new OAuth App
# 3. Set Authorization callback URL
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3001/auth/oauth/github/callback

# API URLs
API_BASE_URL=http://localhost:3001
UI_BASE_URL=http://localhost:5173

# AWS (for Circuit Breaker + CloudWatch)
AWS_REGION=eu-west-2

# Amazon Connect
CONNECT_INSTANCE_ID=your-connect-instance-id

# Bedrock
BEDROCK_REGION=eu-west-2
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Job Queue
BULL_QUEUE_CONCURRENCY=5

# Control Plane Integration (multi-tenant)
CONTROL_PLANE_INTERNAL_URL=http://control-plane:3000
CONTROL_PLANE_INTERNAL_SECRET=your-shared-secret

# Website
ARIA_WEBSITE_URL=http://localhost:3000

# Monitoring
LOG_LEVEL=info

# SaaS Mode (set by Terraform at provision time — do not set manually for local dev)
# TENANT_ID is the unique tenant identifier; its presence enables SaaS mode enforcement
# TENANT_ID=

# Plan limits (overrides tier defaults; set by Terraform from pricing plan)
# PRICING_TIER=individual
# MAX_RUNS_PER_MONTH=200
# MAX_SCENARIOS_PER_RUN=30
# MAX_MODELS=2
# MAX_USERS=1

# Heartbeat interval (seconds, default 600 = 10 min)
HEARTBEAT_INTERVAL_SECONDS=600

# SSM-based config (AWS only, auto-resolved in ECS — do not set for local dev)
# CODEBUILD_PROJECT_NAME=
# CODEBUILD_AWS_REGION=eu-west-2
# CONTROL_PLANE_SECRET_ARN=
