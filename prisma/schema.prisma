// Prisma schema for aria-evaluator-ts
// Run: npm run db:migrate

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BootstrapState {
  id        Int      @id
  createdAt DateTime @default(now())
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  email        String?       @unique
  ssoSubject   String?       @unique
  passwordHash String
  role         String        @default("admin")
  lastLoginAt  DateTime?
  sessions     AuthSession[]
  auditLogs    AuditLog[]
  reviews      Review[]
  baselines    Baseline[]
  experiments  Experiment[]
  schedules    Schedule[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  lastSeenAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  target      String?
  metadataJson String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
}

// ─── Scenario ─────────────────────────────────────────────────────────────────
model Scenario {
  id          String   @id @default(cuid())
  filePath    String   @unique        // stable key, e.g. "scenario:banking_balance_01"
  sourceRef   String?                 // relative source ref, e.g. "banking/account_query.yaml#0"
  name        String
  channel     String                  // "chat" | "voice"
  description String?
  yamlContent String                  // full YAML text of the scenario block
  owner       String?
  lifecycleStatus String @default("active") // draft|active|deprecated
  contentHash String?
  lastRevisionAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  revisions   ScenarioRevision[]
  runs        Run[]
  baselines   Baseline[]
  experiments Experiment[]
  schedules   Schedule[]

  @@index([sourceRef])
  @@index([lifecycleStatus])
}

model ScenarioRevision {
  id         String   @id @default(cuid())
  scenarioId String
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  sourceRef  String
  yamlContent String
  contentHash String
  source     String   // create|edit|sync
  changedBy  String?
  createdAt  DateTime @default(now())

  @@unique([scenarioId, contentHash])
  @@index([scenarioId, createdAt])
}

// ─── Run ──────────────────────────────────────────────────────────────────────
model Run {
  id           String    @id @default(cuid())
  scenarioId   String?
  scenario     Scenario? @relation(fields: [scenarioId], references: [id])
  scenarioName String
  channel      String
  status       String    @default("pending") // pending|running|completed|failed
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  audioPath    String?   // WAV filename under transcripts/audio/ (voice runs)
  job          Job?
  turns        Turn[]
  runEvents    RunEvent[]
  evalResult   EvalResult?
  report       Report?
  experimentRuns ExperimentRun[] @relation("experimentRuns")
  scheduleRuns ScheduleRun[] @relation("scheduleRuns")
  telemetry    RunTelemetry?
  securityAttack SecurityAttack?
  createdAt    DateTime  @default(now())
}

model Job {
  id           String   @id @default(cuid())
  runId        String   @unique
  run          Run      @relation(fields: [runId], references: [id])
  status       String   @default("queued") // queued|running|completed|failed
  payloadJson  String
  attemptCount Int      @default(0)
  workerId     String?
  claimedAt    DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, createdAt])
}

model RunEvent {
  id         Int      @id @default(autoincrement())
  runId      String
  run        Run      @relation(fields: [runId], references: [id])
  eventType  String   // queued|start|log|complete|failed
  payloadJson String
  createdAt  DateTime @default(now())

  @@index([runId, id])
}

// ─── Turn ─────────────────────────────────────────────────────────────────────
model Turn {
  id          String   @id @default(cuid())
  runId       String
  run         Run      @relation(fields: [runId], references: [id])
  index       Int
  role        String   // "customer" | "agent"
  content     String
  durationMs  Int?
  timestampMs BigInt
  createdAt   DateTime @default(now())

  @@index([runId])
}

// ─── EvalResult ───────────────────────────────────────────────────────────────
model EvalResult {
  id              String   @id @default(cuid())
  runId           String   @unique
  run             Run      @relation(fields: [runId], references: [id])
  overallScore    Float
  passed          Boolean
  dimensionScores String   // JSON: Record<string, DimensionScore>
  summary         String
  recommendation  String?
  judgeModel      String
  scenarioType    String?  // 'security' | 'quality'
  judgeTokenInputEstimate  Int?
  judgeTokenOutputEstimate Int?
  judgeTokenTotalEstimate  Int?
  securityScore   Float?   // 0–1, separate axis for security runs
  createdAt       DateTime @default(now())
  review          Review?
}

// ─── Review ───────────────────────────────────────────────────────────────────
model Review {
  id                     String      @id @default(cuid())
  evalResultId           String      @unique
  evalResult             EvalResult  @relation(fields: [evalResultId], references: [id], onDelete: Cascade)
  runId                  String                  // denormalized for efficient queue queries
  status                 String      @default("pending") // pending|in_review|approved|overridden|rejected
  reviewedBy             String?
  reviewer               User?       @relation(fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt             DateTime?
  scoreOverride          Float?                  // 0–10; null = use AI score
  passedOverride         Boolean?                // null = use AI passed
  notes                  String?
  dimensionOverridesJson String?                 // JSON: Record<string, {score: number, notes: string}>
  queuedAt               DateTime    @default(now())
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  @@index([runId])
  @@index([status, queuedAt])
  @@index([reviewedBy])
}

// ─── Regression Analysis ──────────────────────────────────────────────────────
model Baseline {
  id                     String   @id @default(cuid())
  name                   String
  scenarioId             String
  scenario               Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  
  // Metrics captured at baseline time
  totalRuns              Int
  passRate               Float
  avgScore               Float
  avgLatencyMs           Int
  
  // Dimension-level metrics (captured at baseline time)
  dimensionIdsJson       String                  // string[] = which dimensions were included
  dimensionMetricsJson   String                  // Record<dimId, {avg: number, stddev: number}>
  
  // Config snapshot
  judgeModel             String
  judgeVersion           Int
  
  // Regression thresholds (configurable)
  thresholdOverridesJson String?                 // {passRateDrop: 5, scoreDrop: 0.5, latencyIncrease: 20}
  
  createdAt              DateTime @default(now())
  createdBy              String?
  user                   User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  notes                  String?
  
  @@index([scenarioId])
  @@index([createdAt])
  @@index([judgeModel])
  @@index([createdBy])
}

// ─── Experiments ──────────────────────────────────────────────────────────────
model Experiment {
  id          String   @id @default(cuid())
  name        String
  scenarioId  String
  scenario    Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  description String?
  status      String   @default("planning") // planning|running|completed|archived
  createdBy   String?
  user        User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  legs        ExperimentLeg[]
  experimentRuns ExperimentRun[]

  @@index([scenarioId])
  @@index([status])
  @@index([createdBy])
}

model ExperimentLeg {
  id             String   @id @default(cuid())
  experimentId   String
  experiment     Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  name           String
  configJson     String   // JSON: {judgeModel, judgeVersion, overrides?, ...}
  description    String?
  targetRunCount Int?
  createdAt      DateTime @default(now())
  experimentRuns ExperimentRun[]

  @@index([experimentId])
}

model ExperimentRun {
  id           String   @id @default(cuid())
  experimentId String
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  runId        String   @unique  // global uniqueness: one run per experiment
  run          Run      @relation("experimentRuns", fields: [runId], references: [id], onDelete: Cascade)
  legId        String
  leg          ExperimentLeg @relation(fields: [legId], references: [id], onDelete: Cascade)
  tagsJson     String?  // JSON: string[]
  createdAt    DateTime @default(now())

  @@index([experimentId])
  @@index([legId])
}

// ─── Observability ────────────────────────────────────────────────────────────
model RunTelemetry {
  id                 String   @id @default(cuid())
  runId              String   @unique
  run                Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
  provider           String
  channel            String
  status             String   // completed|failed
  latencyMs          Int?
  tokenInputEstimate Int?
  tokenOutputEstimate Int?
  tokenTotalEstimate Int?
  failureClass       String?
  estimatorVersion   Int      @default(1)
  attackCategory     String?  // 'injection'|'evasion'|'exfil'|'policy'|'other' (denorm from SecurityAttack)
  completedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([createdAt])
  @@index([provider, createdAt])
  @@index([failureClass, createdAt])
  @@index([status, createdAt])
  @@index([attackCategory, createdAt])
}

// ─── Security Attacks ────────────────────────────────────────────────────────────
model SecurityAttack {
  id          String  @id @default(cuid())
  runId       String  @unique
  run         Run     @relation(fields: [runId], references: [id], onDelete: Cascade)

  category    String  // 'injection'|'evasion'|'exfil'|'policy'|'other'
  severity    String  // 'low'|'medium'|'high'|'critical'
  confidence  Float   @default(0.5) // 0–1: heuristic confidence or judge-assigned
  inferred    Boolean @default(true) // true=heuristic, false=explicit in scenario YAML

  target      String? // e.g. "system_prompt", "input_validation", null if broad attack
  notes       String? // high-level description (NOT payloads, NOT PII)

  createdAt   DateTime @default(now())

  @@index([category])
  @@index([severity])
  @@index([createdAt])
}

// ─── Report ───────────────────────────────────────────────────────────────────
model Report {
  id        String   @id @default(cuid())
  runId     String   @unique
  run       Run      @relation(fields: [runId], references: [id])
  htmlPath  String   // canonical artifact ref, e.g. reports/report_2026-06-02T21-30-00.html
  jsonPath  String   // canonical artifact ref, e.g. reports/report_2026-06-02T21-30-00.json
  createdAt DateTime @default(now())
}

// ─── Schedules ────────────────────────────────────────────────────────────────
model Schedule {
  id                String   @id @default(cuid())
  name              String   @unique
  description       String?
  status            String   @default("active") // active|paused|archived
  createdBy         String
  user              User     @relation(fields: [createdBy], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  // Scheduling config
  frequency         String   // hourly|daily|weekly|monthly
  cronExpression    String?  // optional cron for power users
  dayOfWeek         Int?     // 0-6 for weekly (0=Sunday)
  hour              Int      // 0-23
  minute            Int      // 0-59
  timezone          String   @default("America/New_York") // IANA timezone

  // Run config
  scenarioId        String?  // FK Scenario.id, NULL = all active
  scenario          Scenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)
  scenarioFile      String?  // path#index alternative
  provider          String   @default("connect")
  channel           String   @default("chat") // chat|voice
  customMetadata    String?  // JSON: arbitrary config

  // Execution tracking
  lastRunAt         DateTime?
  nextRunAt         DateTime // computed: now + frequency
  lastStatus        String?  // pending|completed|failed
  failureCount      Int      @default(0)
  maxFailures       Int      @default(5)

  scheduleRuns      ScheduleRun[]

  @@index([createdBy, status])
  @@index([nextRunAt, status])
  @@index([status])
}

model ScheduleRun {
  id        String   @id @default(cuid())
  scheduleId String
  schedule  Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  runId     String
  run       Run      @relation("scheduleRuns", fields: [runId], references: [id], onDelete: Cascade)
  triggeredAt DateTime @default(now())
  status    String   @default("queued") // queued|running|completed|failed
  completedAt DateTime?
  errorMessage String?
  createdAt DateTime @default(now())

  @@index([scheduleId, triggeredAt])
  @@index([runId])
}
