  contentHash String?
  lastRevisionAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  revisions   ScenarioRevision[]
  runs        Run[]
  baselines   Baseline[]
  experiments Experiment[]
  schedules   Schedule[]

  @@index([sourceRef])
  @@index([lifecycleStatus])
}

model ScenarioRevision {
  id         String   @id @default(cuid())
  scenarioId String
