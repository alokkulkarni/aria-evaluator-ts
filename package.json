{
  "name": "aria-evaluator-ts",
  "version": "1.0.0",
  "description": "ARIA Evaluator — TypeScript/Node.js with Playwright voice + React UI",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run api:dev\" \"wait-on http://localhost:3001/health && npm run ui:dev\"",
    "api:dev": "tsx watch src/api/server.ts",
    "control-plane:dev": "tsx watch src/control-plane/server.ts",
    "ui:dev": "vite",
    "build": "npm run build:api && npm run build:ui",
    "build:api": "tsc -p tsconfig.json",
    "build:ui": "vite build",
    "start": "node dist/api/server.js",
    "control-plane:start": "node dist/control-plane/server.js",
    "cli": "tsx src/cli/run-connect.ts",
    "cli:connect": "tsx src/cli/run-connect.ts",
    "cli:lex": "tsx src/cli/run-lex.ts",
    "cli:azure": "tsx src/cli/run-azure.ts",
    "cli:strands": "tsx src/cli/run-strands.ts",
    "cli:copilot": "tsx src/cli/run-copilot.ts",
    "cli:custom": "tsx src/cli/run-custom.ts",
    "cli:openapi": "tsx src/cli/run-openapi.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "lint": "tsc --noEmit",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-agent-runtime": "^3.1038.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1038.0",
    "@aws-sdk/client-codebuild": "^3.1066.0",
    "@aws-sdk/client-connect": "^3.1038.0",
    "@aws-sdk/client-connectparticipant": "^3.1038.0",
    "@aws-sdk/client-dynamodb": "^3.1067.0",
    "@aws-sdk/client-lex-runtime-v2": "^3.1038.0",
    "@aws-sdk/client-polly": "^3.1038.0",
    "@aws-sdk/client-transcribe-streaming": "^3.1038.0",
    "@aws-sdk/util-dynamodb": "^3.996.4",
    "@deepgram/sdk": "^3.9.0",
    "@prisma/client": "^6.19.3",
    "@roamhq/wrtc": "^0.10.0",
    "amazon-chime-sdk-js": "^3.30.0",
    "axios": "^1.6.5",
    "bcrypt": "^6.0.0",
    "bull": "^4.11.5",
    "cors": "^2.8.5",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "handlebars": "^4.7.8",
    "ioredis": "^5.3.2",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.0",
    "lucide-react": "^1.17.0",
    "password-validator": "^5.3.0",
    "playwright": "^1.51.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "overrides": {
    "tar": ">=7.5.11",
    "uuid": ">=9.0.1",
    "joi": ">=18.2.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bull": "^4.10.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.13.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "wait-on": "^9.0.5"
  }
}
